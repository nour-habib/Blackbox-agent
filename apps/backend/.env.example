# Path to a witsmith-instrumented repo. The backend reads sessions and
# the safety log from <REPO_PATH>/.witsmith/...
REPO_PATH=../cli/witsmith/demo-repo

# DB used by @blackbox/core (Prisma). Should match apps/core/.env so they
# both point at the same SQLite file.
DATABASE_URL="file:../core/prisma/witsmith.db"

# Where the HTTP server listens
PORT=4001
