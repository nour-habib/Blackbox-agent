# Monorepo root (JS workspaces hoist deps here sometimes)
node_modules/

# Junk
.DS_Store
Thumbs.db
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment / secrets — use *.example templates for tracked samples
.env
.env.local
.env.*.local

# Database files
*.db
*.db-journal
*.sqlite
*.sqlite-journal

# Tool runtime / caches
.witsmith/

# Python (packages may define more-specific rules)
.venv/
venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/
